[
  {{- range $i, $e := (where .Site.RegularPages "Section" "posts") -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $e.Title | jsonify }},
    "url": {{ $e.Permalink | jsonify }},
    "description": {{ $e.Description | jsonify }},
    "content": {{ $e.Plain | truncate 300 | jsonify }},
    "date": {{ $e.Date.Format "January 2, 2006" | jsonify }}
  }
  {{- end }}
]
